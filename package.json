    "@next/third-parties": "^16.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "accented": "^1.2.0",
    "date-fns": "^4.0.0",
    "dompurify": "^3.4.1",
    "nanoid": "^5.0.0",
    "next": "16.2.4",
    "next-sitemap": "4.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsc-files": "1.1.4",
    "typescript": "6.0.3"
  },
