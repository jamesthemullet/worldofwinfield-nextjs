{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "next-sitemap.config.js",
    "realtime/server.js",
    "scripts/enrich-tracks.js",
    "lib/imageLoader.ts",
    "__mocks__/**/*.{ts,tsx}",
