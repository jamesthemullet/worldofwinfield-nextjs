{
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 1,
  "prHourlyLimit": 10,
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    }
  ],
  "schedule": [
    "once a day"
  ],
  "timezone": "Europe/London"
}
